generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EXAM_OFFICER
  SUBJECT_TEACHER
  STUDENT
}

enum KeyDateType {
  DEADLINE
  RESULTS
  REGISTRATION
  OTHER
}

enum ResourceType {
  SYLLABUS
  SPECIFICATION
  PAST_PAPER
  MARK_SCHEME
  GUIDE
  LINK
  OTHER
}

enum SourceDocumentType {
  EXAM_TIMETABLE
  KEY_DATES
  REGISTRATION
  RESULTS
  SYLLABUS
  OTHER
}

enum RegistrationWindowStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

enum RegistrationStatus {
  ACTIVE
  CANCELLED
  LOCKED
}

enum RegistrationSource {
  STUDENT_SUBMITTED
  TEACHER_REQUEST_APPROVED
  EO_ASSISTED
  ADMIN_ASSISTED
  EO_FORCED_INTERNAL
  ADMIN_FORCED_INTERNAL
  EO_POST_LOCK_ADJUSTMENT
  ADMIN_POST_LOCK_ADJUSTMENT
  EXTERNAL_CANDIDATE
}

enum RegistrationVisibility {
  STUDENT_AND_TEACHER
  STUDENT_ONLY
  EXAM_OFFICE_ONLY
}

enum BillingScope {
  NORMAL_BILLING
  OFFICE_ONLY_BILLING
  NO_BILLING
  MANUAL_REVIEW
}

enum RegistrationAuditAction {
  ADD
  REMOVE
  SUBMIT
  UPDATE
  CANCEL
  LOCK
  ADMIN_ADJUST
  STUDENT_ADD
  STUDENT_REMOVE
  STUDENT_SUBMIT
  SYSTEM_LOCK
  EO_ADD_AFTER_LOCK
  EO_REMOVE_AFTER_LOCK
  EO_REPLACE_AFTER_LOCK
  ADMIN_ADD_AFTER_LOCK
  ADMIN_REMOVE_AFTER_LOCK
  ADMIN_REPLACE_AFTER_LOCK
  TEACHER_CHANGE_REQUEST
  TEACHER_REQUEST_APPROVED
  TEACHER_REQUEST_REJECTED
  TEACHER_LATE_REGISTRATION_REQUEST
  TEACHER_LATE_REGISTRATION_APPROVED
  TEACHER_LATE_REGISTRATION_REJECTED
  EO_LATE_REGISTRATION_CREATED
  ADMIN_LATE_REGISTRATION_CREATED
  EO_ASSISTED_REGISTRATION_CREATED
  ADMIN_ASSISTED_REGISTRATION_CREATED
  EO_OFFICE_ONLY_REGISTRATION_CREATED
  ADMIN_OFFICE_ONLY_REGISTRATION_CREATED
  EO_POST_LOCK_ADJUSTMENT
  ADMIN_POST_LOCK_ADJUSTMENT
  STUDENT_REGISTRATION_SUBMITTED
  EXTERNAL_CANDIDATE_REGISTRATION_CREATED
  REGISTRATION_STAGE_CREATED
  REGISTRATION_STAGE_UPDATED
  REGISTRATION_STAGE_DISABLED
  FEE_STAGE_CREATED
  FEE_STAGE_UPDATED
  STUDENT_REGISTRATION_OPENED
  STUDENT_REGISTRATION_CLOSED
  REGISTRATION_WINDOW_CLOSED
  ENTRY_TYPE_AUTO_ASSIGNED
  ENTRY_TYPE_OVERRIDDEN
  ENTRY_TYPE_DEFAULTED_TO_NORMAL
  POST_STUDENT_CLOSE_ADJUSTMENT
  POST_WINDOW_CLOSE_OVERRIDE
}

enum RegistrationChangeRequestType {
  ADD_EXAM
  REMOVE_EXAM
  REPLACE_EXAM
  LATE_REGISTRATION
}

enum RegistrationChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FeeEntryType {
  NORMAL
  LATE
  HIGH_LATE
}

enum FeeCurrency {
  GBP
  CNY
}

enum FeeMarkupType {
  PERCENTAGE
  FIXED_AMOUNT
  MANUAL
}

enum FeeStatementDisplayCurrency {
  GBP
  CNY
  BOTH
}

enum FeeStatementStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
  REVISED
  NEEDS_REVIEW
}

enum FeeAuditAction {
  FEE_RULE_CREATED
  FEE_RULE_UPDATED
  EXCHANGE_RATE_UPDATED
  FEE_STATEMENT_GENERATED
  FEE_STATEMENT_BATCH_GENERATED
  FEE_STATEMENT_PRINTED
  FEE_SUMMARY_EXPORTED
  FEE_DETAILS_EXPORTED
}

enum StudentProfileStatus {
  ACTIVE
  GRADUATED
  LEFT
  INACTIVE
}

enum CandidateType {
  INTERNAL
  EXTERNAL
}

enum CandidateStatus {
  ACTIVE
  GRADUATED
  LEFT
  INACTIVE
}

model User {
  id                 String   @id @default(cuid())
  name               String
  username           String?  @unique
  email              String?  @unique
  phone              String?  @unique
  studentNo          String?  @unique
  passwordHash       String
  role               UserRole @default(STUDENT)
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  sourceDocuments       SourceDocument[]
  studentProfile        StudentProfile?
  teacherAssignments    TeacherAssignment[] @relation("TeacherAssignments")
  registrationWindows   RegistrationWindow[] @relation("RegistrationWindowCreator")
  studentRegistrations  StudentExamRegistration[] @relation("StudentRegistrations")
  passwordResetTokens   PasswordResetToken[]
  registrationAuditLogsAsStudent   RegistrationAuditLog[] @relation("RegistrationAuditStudent")
  registrationAuditLogsPerformed RegistrationAuditLog[] @relation("RegistrationAuditPerformer")
  registrationWorkspaces           RegistrationWorkspace[] @relation("StudentRegistrationWorkspaces")
  workspacesLastAdjusted         RegistrationWorkspace[] @relation("WorkspaceLastAdjuster")
  registrationChangeRequests     RegistrationChangeRequest[] @relation("ChangeRequestRequester")
  reviewedChangeRequests           RegistrationChangeRequest[] @relation("ChangeRequestReviewer")
  studentChangeRequests            RegistrationChangeRequest[] @relation("ChangeRequestStudent")
  feeRulesCreated                  FeeRule[] @relation("FeeRuleCreator")
  exchangeRatesCreated             ExchangeRate[] @relation("ExchangeRateCreator")
  feeStatementsGenerated           FeeStatement[] @relation("FeeStatementGenerator")
  feeStatementsAsStudent           FeeStatement[] @relation("FeeStatementStudent")
  feeAuditLogsPerformed            FeeAuditLog[]  @relation("FeeAuditPerformer")
  registrationsAdded               StudentExamRegistration[] @relation("RegistrationAddedBy")
  candidate                          Candidate?

  @@index([role])
  @@index([isActive])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model StudentProfile {
  id               String               @id @default(cuid())
  userId           String               @unique
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentNo        String               @unique
  currentGrade     String
  currentClassName String
  email            String?
  phone            String?
  status           StudentProfileStatus @default(ACTIVE)
  entryYear        Int?
  graduationYear   Int?
  graduatedAt      DateTime?
  leftAt           DateTime?
  archivedAt       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([currentGrade])
  @@index([currentClassName])
  @@index([status])
  @@index([studentNo])
}

model Candidate {
  id                           String          @id @default(cuid())
  assessmentHubCandidateNumber String
  candidateType                CandidateType
  userId                       String?         @unique
  user                         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  studentNumber                String?
  englishName                  String
  chineseName                  String?
  email                        String?
  phone                        String?
  dateOfBirth                  DateTime?
  gender                       String?
  idNumber                     String?
  passportNumber               String?
  schoolName                   String?
  grade                        String?
  className                    String?
  status                       CandidateStatus @default(ACTIVE)
  loginEnabled                 Boolean         @default(false)
  sourceSystem                 String?
  externalId                   String?
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt

  examIdentities         CandidateExamIdentity[]
  registrationWorkspaces RegistrationWorkspace[]
  examRegistrations      StudentExamRegistration[]
  auditLogs              RegistrationAuditLog[]
  changeRequests         RegistrationChangeRequest[]
  feeStatements          FeeStatement[]

  @@index([candidateType])
  @@index([status])
  @@index([assessmentHubCandidateNumber])
  @@index([studentNumber])
  @@index([englishName])
  @@index([grade])
  @@index([className])
  @@index([externalId])
}

model CandidateExamIdentity {
  id                   String    @id @default(cuid())
  candidateId          String
  candidate            Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  examBoardId          String
  examBoard            ExamBoard @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  centreNumber         String?
  boardCandidateNumber String?
  uci                  String?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([candidateId, examBoardId])
  @@index([candidateId])
  @@index([examBoardId])
  @@index([boardCandidateNumber])
}

model TeacherAssignment {
  id        String   @id @default(cuid())
  teacherId String
  teacher   User     @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, subjectId])
  @@index([teacherId])
  @@index([subjectId])
}

model RegistrationWindow {
  id           String                   @id @default(cuid())
  examBoardId  String
  examBoard    ExamBoard                @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  examSeriesId String
  examSeries   ExamSeries               @relation(fields: [examSeriesId], references: [id], onDelete: Cascade)
  title        String
  studentRegistrationOpenAt  DateTime
  studentRegistrationCloseAt DateTime
  registrationCloseAt        DateTime
  status       RegistrationWindowStatus @default(DRAFT)
  studentSelfRegistrationEnabled Boolean @default(true)
  eoAssistedRegistrationEnabled  Boolean @default(true)
  officeOnlyRegistrationEnabled  Boolean @default(true)
  postLockAdjustmentEnabled      Boolean @default(true)
  createdById  String?
  createdBy    User?                    @relation("RegistrationWindowCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  registrations StudentExamRegistration[]
  workspaces    RegistrationWorkspace[]
  changeRequests RegistrationChangeRequest[]
  feeStages     RegistrationFeeStage[]
  registrationAuditLogs RegistrationAuditLog[]
  feeRules       FeeRule[]
  exchangeRates  ExchangeRate[]
  feeStatements  FeeStatement[]
  feeAuditLogs   FeeAuditLog[]

  @@index([examBoardId])
  @@index([examSeriesId])
  @@index([status])
  @@index([studentRegistrationOpenAt, studentRegistrationCloseAt, registrationCloseAt], map: "RegistrationWindow_timing_idx")
}

model RegistrationFeeStage {
  id                   String           @id @default(cuid())
  registrationWindowId String
  registrationWindow   RegistrationWindow @relation(fields: [registrationWindowId], references: [id], onDelete: Cascade)
  stageCode            FeeEntryType
  stageName            String
  sequence             Int
  startAt              DateTime
  endAt                DateTime
  enabled              Boolean          @default(true)
  notes                String?          @db.Text
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  workspaces    RegistrationWorkspace[]
  registrations StudentExamRegistration[]
  auditLogs     RegistrationAuditLog[]

  @@unique([registrationWindowId, stageCode])
  @@index([registrationWindowId])
  @@index([enabled])
  @@index([sequence])
}

model RegistrationWorkspace {
  id                   String   @id @default(cuid())
  candidateId          String?
  candidate            Candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  studentId            String?
  student              User?    @relation("StudentRegistrationWorkspaces", fields: [studentId], references: [id], onDelete: Cascade)
  registrationWindowId String
  registrationWindow   RegistrationWindow @relation(fields: [registrationWindowId], references: [id], onDelete: Cascade)

  lockedAt              DateTime?
  lastAdjustedByUserId  String?
  lastAdjustedByUser    User?     @relation("WorkspaceLastAdjuster", fields: [lastAdjustedByUserId], references: [id], onDelete: SetNull)
  lastAdjustedByRole    UserRole?
  lastAdjustedAt        DateTime?
  lastAdjustmentReason  String?   @db.Text
  lastAdjustmentSummary String?   @db.Text
  hasPostLockAdjustment Boolean   @default(false)
  isLateRegistration    Boolean   @default(false)
  entryType             FeeEntryType @default(NORMAL)
  feeStageId            String?
  feeStage              RegistrationFeeStage? @relation(fields: [feeStageId], references: [id], onDelete: SetNull)
  entryTypeOverridden   Boolean   @default(false)
  entryTypeOverrideReason String? @db.Text
  registrationSource    RegistrationSource     @default(STUDENT_SUBMITTED)
  visibility            RegistrationVisibility @default(STUDENT_AND_TEACHER)
  billingScope          BillingScope           @default(NORMAL_BILLING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations  StudentExamRegistration[]
  auditLogs      RegistrationAuditLog[]
  changeRequests RegistrationChangeRequest[]
  feeStatements  FeeStatement[]

  @@unique([candidateId, registrationWindowId])
  @@unique([studentId, registrationWindowId])
  @@index([candidateId])
  @@index([studentId])
  @@index([registrationWindowId])
  @@index([hasPostLockAdjustment])
  @@index([registrationSource])
  @@index([visibility])
  @@index([billingScope])
  @@index([entryType])
  @@index([feeStageId])
}

model StudentExamRegistration {
  id                     String                @id @default(cuid())
  candidateId            String?
  candidate              Candidate?            @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  studentId              String?
  student                User?                 @relation("StudentRegistrations", fields: [studentId], references: [id], onDelete: Cascade)
  registrationWorkspaceId String?
  registrationWorkspace  RegistrationWorkspace? @relation(fields: [registrationWorkspaceId], references: [id], onDelete: SetNull)
  examSessionId        String
  examSession          ExamSession        @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  registrationWindowId String
  registrationWindow   RegistrationWindow @relation(fields: [registrationWindowId], references: [id], onDelete: Cascade)
  examBoardId          String
  examBoard            ExamBoard          @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  examSeriesId         String
  examSeries           ExamSeries         @relation(fields: [examSeriesId], references: [id], onDelete: Cascade)
  subjectId            String
  subject              Subject            @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  paperId              String
  paper                Paper              @relation(fields: [paperId], references: [id], onDelete: Cascade)

  studentNameSnapshot  String
  studentNoSnapshot    String
  gradeSnapshot        String
  classNameSnapshot    String
  emailSnapshot        String?
  phoneSnapshot        String?
  assessmentHubCandidateNumberSnapshot String?
  candidateTypeSnapshot              CandidateType?

  status      RegistrationStatus @default(ACTIVE)
  lockedAt    DateTime?
  cancelledAt DateTime?
  registrationSource RegistrationSource     @default(STUDENT_SUBMITTED)
  visibility         RegistrationVisibility @default(STUDENT_AND_TEACHER)
  billingScope       BillingScope           @default(NORMAL_BILLING)
  addedByUserId      String?
  addedByUser        User?                  @relation("RegistrationAddedBy", fields: [addedByUserId], references: [id], onDelete: SetNull)
  addedByRole        UserRole?
  addedAt            DateTime?
  reason             String?   @db.Text
  entryType          FeeEntryType @default(NORMAL)
  feeStageId         String?
  feeStage           RegistrationFeeStage? @relation(fields: [feeStageId], references: [id], onDelete: SetNull)
  entryTypeOverridden Boolean  @default(false)
  entryTypeOverrideReason String? @db.Text
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  auditLogs RegistrationAuditLog[]

  @@unique([candidateId, examSessionId])
  @@unique([studentId, examSessionId])
  @@index([candidateId])
  @@index([studentId])
  @@index([registrationWorkspaceId])
  @@index([examSessionId])
  @@index([registrationWindowId])
  @@index([examBoardId])
  @@index([examSeriesId])
  @@index([subjectId])
  @@index([status])
  @@index([registrationSource])
  @@index([visibility])
  @@index([billingScope])
  @@index([gradeSnapshot, classNameSnapshot])
  @@index([studentNoSnapshot])
  @@index([entryType])
  @@index([feeStageId])
}

model RegistrationAuditLog {
  id                      String                  @id @default(cuid())
  registrationWorkspaceId String?
  registrationWorkspace   RegistrationWorkspace?  @relation(fields: [registrationWorkspaceId], references: [id], onDelete: SetNull)
  registrationWindowId    String?
  registrationWindow      RegistrationWindow?     @relation(fields: [registrationWindowId], references: [id], onDelete: Cascade)
  candidateId             String?
  candidate               Candidate?              @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  studentId               String?
  student                 User?                   @relation("RegistrationAuditStudent", fields: [studentId], references: [id], onDelete: Cascade)
  registrationId          String?
  registration            StudentExamRegistration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  feeStageId              String?
  feeStage                RegistrationFeeStage?   @relation(fields: [feeStageId], references: [id], onDelete: SetNull)
  examSessionId           String?
  examSession             ExamSession?            @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  action                  RegistrationAuditAction
  performedById             String
  performedBy               User                    @relation("RegistrationAuditPerformer", fields: [performedById], references: [id], onDelete: Cascade)
  performedByRole           UserRole?
  performedAt               DateTime                @default(now())
  entryType                 FeeEntryType?
  beforeValue               String?   @db.Text
  afterValue                String?   @db.Text
  reason                    String?   @db.Text
  registrationSource        RegistrationSource?
  visibility                RegistrationVisibility?
  billingScope              BillingScope?
  assessmentHubCandidateNumberSnapshot String?
  candidateTypeSnapshot                CandidateType?
  note                      String?   @db.Text
  createdAt                 DateTime                @default(now())

  @@index([registrationWorkspaceId])
  @@index([registrationWindowId])
  @@index([candidateId])
  @@index([studentId])
  @@index([registrationId])
  @@index([feeStageId])
  @@index([examSessionId])
  @@index([performedById])
  @@index([performedAt])
}

model RegistrationChangeRequest {
  id                       String                          @id @default(cuid())
  registrationWorkspaceId  String?
  registrationWorkspace    RegistrationWorkspace?          @relation(fields: [registrationWorkspaceId], references: [id], onDelete: Cascade)
  registrationWindowId     String?
  registrationWindow       RegistrationWindow?             @relation(fields: [registrationWindowId], references: [id], onDelete: Cascade)
  studentId                String?
  student                  User?                           @relation("ChangeRequestStudent", fields: [studentId], references: [id], onDelete: Cascade)
  candidateId              String?
  candidate                Candidate?                      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  requestedByUserId        String
  requestedBy              User                            @relation("ChangeRequestRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  requestedByRole          UserRole
  requestType              RegistrationChangeRequestType
  targetExamSessionId      String?
  targetExamSession        ExamSession?                    @relation("ChangeRequestTargetSession", fields: [targetExamSessionId], references: [id], onDelete: SetNull)
  targetRegistrationId     String?
  replacementExamSessionId String?
  replacementExamSession   ExamSession?                    @relation("ChangeRequestReplacementSession", fields: [replacementExamSessionId], references: [id], onDelete: SetNull)
  reason                   String    @db.Text
  status                   RegistrationChangeRequestStatus @default(PENDING)
  reviewedByUserId         String?
  reviewedBy               User?                           @relation("ChangeRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewedAt               DateTime?
  reviewNote               String?   @db.Text
  createdAt                DateTime                        @default(now())
  updatedAt                DateTime                        @updatedAt

  examSessions RegistrationChangeRequestExamSession[]

  @@index([registrationWorkspaceId])
  @@index([registrationWindowId])
  @@index([candidateId])
  @@index([studentId])
  @@index([requestedByUserId])
  @@index([status])
}

model RegistrationChangeRequestExamSession {
  id              String                    @id @default(cuid())
  changeRequestId String
  changeRequest   RegistrationChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  examSessionId   String
  examSession     ExamSession               @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  createdAt       DateTime                  @default(now())

  @@unique([changeRequestId, examSessionId])
  @@index([changeRequestId])
  @@index([examSessionId])
}

model ExamBoard {
  id                           String   @id @default(cuid())
  name                         String
  code                         String   @unique
  description                  String?
  country                      String
  region                       String?
  website                      String?
  timezone                     String?
  calendarSubjectFilterEnabled Boolean  @default(false)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  qualifications            Qualification[]
  examSeries                ExamSeries[]
  keyDates                  KeyDate[]
  resources                 Resource[]
  sourceDocuments           SourceDocument[]
  calendarSubjectSelections CalendarSubjectSelection[]
  registrationWindows       RegistrationWindow[]
  studentExamRegistrations  StudentExamRegistration[]
  feeRules                  FeeRule[]
  candidateExamIdentities   CandidateExamIdentity[]

  @@index([country])
}

model Qualification {
  id          String    @id @default(cuid())
  name        String
  level       String
  code        String?
  examBoardId String
  examBoard   ExamBoard @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  subjects  Subject[]
  resources Resource[]
  feeRules  FeeRule[]

  @@index([examBoardId])
}

model Subject {
  id              String        @id @default(cuid())
  name            String
  code            String
  qualificationId String
  qualification   Qualification @relation(fields: [qualificationId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  papers                    Paper[]
  keyDates                  KeyDate[]
  resources                 Resource[]
  calendarSubjectSelections CalendarSubjectSelection[]
  teacherAssignments        TeacherAssignment[]
  studentExamRegistrations  StudentExamRegistration[]
  feeRules                  FeeRule[]

  @@index([qualificationId])
}

model CalendarSubjectSelection {
  id          String    @id @default(cuid())
  examBoardId String
  examBoard   ExamBoard @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([examBoardId, subjectId])
  @@index([examBoardId])
  @@index([subjectId])
}

model Paper {
  id               String          @id @default(cuid())
  code             String
  title            String
  duration         Int?
  subjectId        String
  subject          Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  examSessions             ExamSession[]
  resources                Resource[]
  studentExamRegistrations StudentExamRegistration[]
  feeRules                 FeeRule[]

  @@index([subjectId])
  @@index([sourceDocumentId])
}

model ExamSeries {
  id               String          @id @default(cuid())
  name             String
  year             Int
  examBoardId      String
  examBoard        ExamBoard       @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  startDate        DateTime?
  endDate          DateTime?
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  examSessions             ExamSession[]
  keyDates                 KeyDate[]
  resources                Resource[]
  registrationWindows      RegistrationWindow[]
  studentExamRegistrations StudentExamRegistration[]
  feeRules                 FeeRule[]

  @@index([examBoardId])
  @@index([year])
  @@index([sourceDocumentId])
}

model ExamSession {
  id               String          @id @default(cuid())
  date             DateTime
  startTime        String?
  endTime          String?
  timezone         String?
  venue            String?
  notes            String?
  paperId          String
  paper            Paper           @relation(fields: [paperId], references: [id], onDelete: Cascade)
  examSeriesId     String
  examSeries       ExamSeries      @relation(fields: [examSeriesId], references: [id], onDelete: Cascade)
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  studentExamRegistrations StudentExamRegistration[]
  registrationAuditLogs    RegistrationAuditLog[]
  changeRequestTargets     RegistrationChangeRequest[] @relation("ChangeRequestTargetSession")
  changeRequestReplacements RegistrationChangeRequest[] @relation("ChangeRequestReplacementSession")
  changeRequestExamSessions RegistrationChangeRequestExamSession[]
  feeRules                  FeeRule[]
  feeStatementItems         FeeStatementItem[]

  @@index([paperId])
  @@index([examSeriesId])
  @@index([date])
  @@index([sourceDocumentId])
}

model KeyDate {
  id               String          @id @default(cuid())
  title            String
  date             DateTime
  type             KeyDateType     @default(OTHER)
  description      String?
  timezone         String?
  examBoardId      String?
  examBoard        ExamBoard?      @relation(fields: [examBoardId], references: [id], onDelete: SetNull)
  subjectId        String?
  subject          Subject?        @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  examSeriesId     String?
  examSeries       ExamSeries?     @relation(fields: [examSeriesId], references: [id], onDelete: SetNull)
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([date])
  @@index([examBoardId])
  @@index([subjectId])
  @@index([examSeriesId])
  @@index([sourceDocumentId])
}

model Resource {
  id               String          @id @default(cuid())
  title            String
  description      String?
  url              String?
  filePath         String?
  type             ResourceType    @default(OTHER)
  language         String?
  examBoardId      String?
  examBoard        ExamBoard?      @relation(fields: [examBoardId], references: [id], onDelete: SetNull)
  qualificationId  String?
  qualification    Qualification?  @relation(fields: [qualificationId], references: [id], onDelete: SetNull)
  subjectId        String?
  subject          Subject?        @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  paperId          String?
  paper            Paper?          @relation(fields: [paperId], references: [id], onDelete: SetNull)
  examSeriesId     String?
  examSeries       ExamSeries?     @relation(fields: [examSeriesId], references: [id], onDelete: SetNull)
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([examBoardId])
  @@index([qualificationId])
  @@index([subjectId])
  @@index([paperId])
  @@index([examSeriesId])
  @@index([sourceDocumentId])
  @@index([type])
}

model SourceDocument {
  id           String             @id @default(cuid())
  title        String
  type         SourceDocumentType @default(OTHER)
  sourceUrl    String?
  fileName     String?
  fileHash     String?
  publishedAt  DateTime?
  fetchedAt    DateTime?
  notes        String?
  examBoardId  String?
  examBoard    ExamBoard?         @relation(fields: [examBoardId], references: [id], onDelete: SetNull)
  uploadedById String?
  uploadedBy   User?              @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  papers       Paper[]
  examSeries   ExamSeries[]
  examSessions ExamSession[]
  keyDates     KeyDate[]
  resources    Resource[]

  @@index([examBoardId])
  @@index([uploadedById])
  @@index([type])
  @@index([publishedAt])
}

model FeeRule {
  id                   String           @id @default(cuid())
  registrationWindowId String
  registrationWindow   RegistrationWindow @relation(fields: [registrationWindowId], references: [id], onDelete: Cascade)
  examBoardId          String
  examBoard            ExamBoard        @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  examSeriesId         String
  examSeries           ExamSeries       @relation(fields: [examSeriesId], references: [id], onDelete: Cascade)
  qualificationId      String
  qualification        Qualification    @relation(fields: [qualificationId], references: [id], onDelete: Cascade)
  subjectId            String?
  subject              Subject?         @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  paperId              String?
  paper                Paper?           @relation(fields: [paperId], references: [id], onDelete: SetNull)
  examSessionId        String?
  examSession          ExamSession?     @relation(fields: [examSessionId], references: [id], onDelete: SetNull)
  entryType            FeeEntryType     @default(NORMAL)
  costCurrency         FeeCurrency
  costAmount           Decimal          @db.Decimal(12, 2)
  exchangeRateToCny    Decimal?         @db.Decimal(12, 4)
  markupType           FeeMarkupType
  markupValue          Decimal?         @db.Decimal(12, 2)
  salesCurrency        FeeCurrency
  salesAmount          Decimal?         @db.Decimal(12, 2)
  isActive             Boolean          @default(true)
  createdByUserId      String?
  createdBy            User?            @relation("FeeRuleCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([registrationWindowId])
  @@index([examBoardId])
  @@index([examSeriesId])
  @@index([qualificationId])
  @@index([subjectId])
  @@index([paperId])
  @@index([examSessionId])
  @@index([entryType])
  @@index([isActive])
}

model ExchangeRate {
  id                   String           @id @default(cuid())
  registrationWindowId String
  registrationWindow   RegistrationWindow @relation(fields: [registrationWindowId], references: [id], onDelete: Cascade)
  baseCurrency         FeeCurrency
  targetCurrency       FeeCurrency
  rate                 Decimal          @db.Decimal(12, 4)
  effectiveDate        DateTime
  createdByUserId      String?
  createdBy            User?            @relation("ExchangeRateCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([registrationWindowId])
  @@index([baseCurrency, targetCurrency])
  @@index([effectiveDate])
}

model FeeStatement {
  id                      String                      @id @default(cuid())
  candidateId             String?
  candidate               Candidate?                  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  studentId               String?
  student                 User?                       @relation("FeeStatementStudent", fields: [studentId], references: [id], onDelete: Cascade)
  registrationWorkspaceId String
  registrationWorkspace   RegistrationWorkspace       @relation(fields: [registrationWorkspaceId], references: [id], onDelete: Cascade)
  registrationWindowId    String
  registrationWindow      RegistrationWindow          @relation(fields: [registrationWindowId], references: [id], onDelete: Cascade)
  statementNo             String                      @unique
  displayCurrency         FeeStatementDisplayCurrency @default(BOTH)
  exchangeRateSnapshot    Decimal?                    @db.Decimal(12, 4)
  studentNameSnapshot     String
  studentNoSnapshot       String
  gradeSnapshot           String
  classNameSnapshot       String
  emailSnapshot           String?
  assessmentHubCandidateNumberSnapshot String?
  candidateTypeSnapshot                CandidateType?
  status                  FeeStatementStatus          @default(DRAFT)
  totalGbpAmount          Decimal                     @db.Decimal(12, 2)
  totalCnyAmount          Decimal                     @db.Decimal(12, 2)
  paymentNotes            String?                     @db.Text
  generatedByUserId       String
  generatedBy             User                        @relation("FeeStatementGenerator", fields: [generatedByUserId], references: [id], onDelete: Cascade)
  generatedAt             DateTime                    @default(now())
  issuedAt                DateTime?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  items FeeStatementItem[]

  @@index([candidateId])
  @@index([studentId])
  @@index([registrationWorkspaceId])
  @@index([registrationWindowId])
  @@index([status])
  @@index([statementNo])
}

model FeeStatementItem {
  id                      String                      @id @default(cuid())
  feeStatementId          String
  feeStatement            FeeStatement                @relation(fields: [feeStatementId], references: [id], onDelete: Cascade)
  examSessionId           String?
  examSession             ExamSession?                @relation(fields: [examSessionId], references: [id], onDelete: SetNull)
  examBoardSnapshot       String
  qualificationSnapshot   String
  subjectSnapshot         String
  paperCodeSnapshot       String
  paperTitleSnapshot      String
  entryTypeSnapshot       FeeEntryType
  costCurrencySnapshot    FeeCurrency
  costAmountSnapshot      Decimal                     @db.Decimal(12, 2)
  exchangeRateSnapshot    Decimal?                    @db.Decimal(12, 4)
  markupTypeSnapshot      FeeMarkupType
  markupValueSnapshot     Decimal?                    @db.Decimal(12, 2)
  salesGbpAmountSnapshot  Decimal                     @db.Decimal(12, 2)
  salesCnyAmountSnapshot  Decimal                     @db.Decimal(12, 2)
  displayCurrencySnapshot FeeStatementDisplayCurrency
  lineTotalGbp            Decimal                     @db.Decimal(12, 2)
  lineTotalCny            Decimal                     @db.Decimal(12, 2)
  quantity                Int                         @default(1)
  createdAt               DateTime                    @default(now())

  @@index([feeStatementId])
  @@index([examSessionId])
}

model FeeAuditLog {
  id                   String          @id @default(cuid())
  action               FeeAuditAction
  registrationWindowId String?
  registrationWindow   RegistrationWindow? @relation(fields: [registrationWindowId], references: [id], onDelete: SetNull)
  performedByUserId    String
  performedBy          User            @relation("FeeAuditPerformer", fields: [performedByUserId], references: [id], onDelete: Cascade)
  performedAt          DateTime        @default(now())
  metadata             String?   @db.Text
  note                 String?   @db.Text

  @@index([registrationWindowId])
  @@index([performedByUserId])
  @@index([action])
  @@index([performedAt])
}
