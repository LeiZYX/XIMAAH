# Copy to .env on the production server:
#   cp .env.production.example .env

# --- MySQL (docker-compose mysql service) ---
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=xima_assessment_hub
MYSQL_USER=xima
MYSQL_PASSWORD=change-me-app-password

# Host must be the docker-compose service name "mysql", not localhost.
DATABASE_URL="mysql://xima:change-me-app-password@mysql:3306/xima_assessment_hub?connection_limit=5&pool_timeout=20"

# --- App auth & URLs ---
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
NEXTAUTH_URL=https://exam.shssip-iedu.cn
APP_URL=https://exam.shssip-iedu.cn
APP_BASE_URL=https://exam.shssip-iedu.cn
NODE_ENV=production

# --- Initial admin (used by prisma db seed) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password
ADMIN_NAME=Admin

# --- Optional ---
EXAM_OFFICER_CAN_CONFIGURE_FEE_RULES=false
STUDENT_FEE_STATEMENTS_ENABLED=false
# DATA_PROCESSOR_URL=

# --- SMTP (password reset emails) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=notifications@example.com
# SMTP_PASSWORD=change-me
# MAIL_FROM="XIMA Assessment Hub <notifications@example.com>"
# PASSWORD_RESET_EXPIRES_MINUTES=60
