  examBoard          ExamBoard          @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  examSeriesId       String
  examSeries         ExamSeries         @relation(fields: [examSeriesId], references: [id], onDelete: Cascade)
  title              String
  resultsReleaseDate DateTime?
  openAt             DateTime
  closeAt            DateTime
  status             ReviewWindowStatus @default(DRAFT)
  notes              String?            @db.Text
  createdByUserId    String?
  createdBy          User?              @relation("ReviewWindowCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  services               ReviewWindowService[]
  reviewRequests         ReviewRequest[]
  cashInRequests         CashInRequest[]
  accessToScriptRequests AccessToScriptRequest[]
  certificateRequests    CertificateRequest[]
  feeStatements          FeeStatement[]
  postResultsAuditLogs   PostResultsAuditLog[]

  @@index([examBoardId])
  @@index([examSeriesId])
  @@index([status])
  @@index([openAt, closeAt])
}

model ReviewWindowService {
  id             String                @id @default(cuid())
  reviewWindowId String
  reviewWindow   ReviewWindow          @relation(fields: [reviewWindowId], references: [id], onDelete: Cascade)
  serviceType    PostResultServiceType
  enabled        Boolean               @default(false)
  notes          String?               @db.Text
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([reviewWindowId, serviceType])
  @@index([reviewWindowId])
}

model ReviewRequest {
  id                 String                   @id @default(cuid())
  reviewWindowId     String
  reviewWindow       ReviewWindow             @relation(fields: [reviewWindowId], references: [id], onDelete: Cascade)
  candidateId        String
  candidate          Candidate                @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  examBoardId        String
  examBoard          ExamBoard                @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  examSeriesId       String
  examSeries         ExamSeries               @relation(fields: [examSeriesId], references: [id], onDelete: Cascade)
  registrationItemId String?
  registrationItem   StudentExamRegistration? @relation("ReviewRequestRegistrationItem", fields: [registrationItemId], references: [id], onDelete: SetNull)
  examSessionId      String?
  examSession        ExamSession?             @relation(fields: [examSessionId], references: [id], onDelete: SetNull)
  subjectId          String?
  subject            Subject?                 @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  paperId            String?
  paper              Paper?                   @relation(fields: [paperId], references: [id], onDelete: SetNull)
  serviceType        PostResultServiceType
  reviewType         String?
  priority           Boolean                  @default(false)
  status             ReviewRequestStatus      @default(DRAFT)
  requestedByUserId  String
  requestedBy        User                     @relation("ReviewRequestRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewedByUserId   String?
  reviewedBy         User?                    @relation("ReviewRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  resultOutcome      String?
  reason             String?                  @db.Text
  notes              String?                  @db.Text
  feeStatementId     String?
  feeStatement       FeeStatement?            @relation(fields: [feeStatementId], references: [id], onDelete: SetNull)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([reviewWindowId])
  @@index([candidateId])
  @@index([examBoardId])
  @@index([examSeriesId])
  @@index([serviceType])
  @@index([status])
  @@index([registrationItemId])
}

model CashInRequest {
  id                String                  @id @default(cuid())
  reviewWindowId    String
  reviewWindow      ReviewWindow            @relation(fields: [reviewWindowId], references: [id], onDelete: Cascade)
  candidateId       String
  candidate         Candidate               @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  examBoardId       String
  examBoard         ExamBoard               @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  examSeriesId      String
  examSeries        ExamSeries              @relation(fields: [examSeriesId], references: [id], onDelete: Cascade)
  qualificationId   String?
  qualification     Qualification?          @relation(fields: [qualificationId], references: [id], onDelete: SetNull)
  subjectId         String?
  subject           Subject?                @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  status            PostResultRequestStatus @default(DRAFT)
  requestedByUserId String
  requestedBy       User                    @relation("CashInRequestRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reason            String?                 @db.Text
  notes             String?                 @db.Text
  feeStatementId    String?
  feeStatement      FeeStatement?           @relation(fields: [feeStatementId], references: [id], onDelete: SetNull)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([reviewWindowId])
  @@index([candidateId])
  @@index([examBoardId])
  @@index([status])
}

model AccessToScriptRequest {
