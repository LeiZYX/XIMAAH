}

enum CandidateType {
  INTERNAL
  EXTERNAL
}

enum CandidateStatus {
  ACTIVE
  GRADUATED
  LEFT
  INACTIVE
}

model User {
  id                 String   @id @default(cuid())
  name               String
  username           String?  @unique
  email              String?  @unique
  phone              String?  @unique
  studentNo          String?  @unique
  passwordHash       String
  role               UserRole @default(STUDENT)
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  sourceDocuments                  SourceDocument[]
  studentProfile                   StudentProfile?
  teacherAssignments               TeacherAssignment[]         @relation("TeacherAssignments")
  registrationWindows              RegistrationWindow[]        @relation("RegistrationWindowCreator")
  studentRegistrations             StudentExamRegistration[]   @relation("StudentRegistrations")
  passwordResetTokens              PasswordResetToken[]
  registrationAuditLogsAsStudent   RegistrationAuditLog[]      @relation("RegistrationAuditStudent")
  registrationAuditLogsPerformed   RegistrationAuditLog[]      @relation("RegistrationAuditPerformer")
  registrationWorkspaces           RegistrationWorkspace[]     @relation("StudentRegistrationWorkspaces")
  workspacesLastAdjusted           RegistrationWorkspace[]     @relation("WorkspaceLastAdjuster")
  registrationChangeRequests       RegistrationChangeRequest[] @relation("ChangeRequestRequester")
  reviewedChangeRequests           RegistrationChangeRequest[] @relation("ChangeRequestReviewer")
  studentChangeRequests            RegistrationChangeRequest[] @relation("ChangeRequestStudent")
  feeRulesCreated                  FeeRule[]                   @relation("FeeRuleCreator")
  exchangeRatesCreated             ExchangeRate[]              @relation("ExchangeRateCreator")
  feeStatementsGenerated           FeeStatement[]              @relation("FeeStatementGenerator")
  feeStatementsAsStudent           FeeStatement[]              @relation("FeeStatementStudent")
  feeStatementsRegenerationChanged FeeStatement[]              @relation("FeeStatementRegenerationChanged")
  feeAuditLogsPerformed            FeeAuditLog[]               @relation("FeeAuditPerformer")
  registrationsAdded               StudentExamRegistration[]   @relation("RegistrationAddedBy")
  candidate                        Candidate?
  teacherProfile                   TeacherProfile?
  userAuditLogsPerformed           UserAuditLog[]              @relation("UserAuditPerformer")
  userAuditLogsTarget              UserAuditLog[]              @relation("UserAuditTarget")
  restrictedRegistrationsCreated   RegistrationWorkspace[]     @relation("RestrictedRegistrationCreator")
  restrictedRegistrationsUpdated   RegistrationWorkspace[]     @relation("RestrictedRegistrationUpdater")
  examDocumentAuditLogsPerformed   ExamDocumentAuditLog[]      @relation("ExamDocumentAuditPerformer")
  candidateAuditLogsPerformed      CandidateAuditLog[]         @relation("CandidateAuditPerformer")
  reviewWindowsCreated             ReviewWindow[]              @relation("ReviewWindowCreator")
  feeSchedulesCreated              FeeSchedule[]               @relation("FeeScheduleCreator")
  reviewRequestsRequested          ReviewRequest[]             @relation("ReviewRequestRequester")
  reviewRequestsReviewed           ReviewRequest[]             @relation("ReviewRequestReviewer")
  cashInRequestsRequested          CashInRequest[]             @relation("CashInRequestRequester")
  accessToScriptRequestsRequested  AccessToScriptRequest[]     @relation("AccessToScriptRequester")
  certificateRequestsRequested     CertificateRequest[]        @relation("CertificateRequestRequester")
  postResultsAuditLogsPerformed    PostResultsAuditLog[]       @relation("PostResultsAuditPerformer")
  backupSettingsUpdated            BackupSetting[]             @relation("BackupSettingsUpdater")
  backupJobsTriggered              BackupJob[]                 @relation("BackupJobTriggeredBy")

  @@index([role])
  @@index([isActive])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model StudentProfile {
  id               String               @id @default(cuid())
  userId           String               @unique
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentNo        String               @unique
  currentGrade     Grade
  currentClassName String
  idCardNumber     String?
  gender           Gender?
  email            String?
  phone            String?
  status           StudentProfileStatus @default(ACTIVE)
  entryYear        Int?
  graduationYear   Int?
  graduatedAt      DateTime?
  leftAt           DateTime?
  archivedAt       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([currentGrade])
  @@index([currentClassName])
  @@index([status])
  @@index([studentNo])
}

model StudentIdSequence {
  year       Int @id
  lastNumber Int
}

model TeacherProfile {
  id             String               @id @default(cuid())
  userId         String               @unique
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone          String?
  email          String?
  status         TeacherProfileStatus @default(ACTIVE)
  visibleGrades  Json?
  visibleClasses Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([status])
}

model SystemEmailSettings {
  id                          String   @id @default("default")
  smtpHost                    String?
  smtpPort                    Int      @default(587)
  smtpSecure                  Boolean  @default(false)
  smtpUser                    String?
  smtpPassword                String?
  mailFrom                    String?
  passwordResetExpiresMinutes Int      @default(60)
  appUrl                      String?
  updatedAt                   DateTime @updatedAt
}

model UserAuditLog {
  id            String          @id @default(cuid())
  action        UserAuditAction
  targetUserId  String?
  targetUser    User?           @relation("UserAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  performedById String
  performedBy   User            @relation("UserAuditPerformer", fields: [performedById], references: [id], onDelete: Cascade)
  metadata      Json?
  createdAt     DateTime        @default(now())

  @@index([action])
  @@index([targetUserId])
  @@index([performedById])
  @@index([createdAt])
}

model ExamDocumentAuditLog {
  id                   String                  @id @default(cuid())
  action               ExamDocumentAuditAction
  documentType         ExamDocumentType?
  registrationWindowId String?
  registrationWindow   RegistrationWindow?     @relation(fields: [registrationWindowId], references: [id], onDelete: SetNull)
  examSessionId        String?
  examSession          ExamSession?            @relation(fields: [examSessionId], references: [id], onDelete: SetNull)
  candidateId          String?
  candidate            Candidate?              @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  candidateCount       Int?
  performedById        String
  performedBy          User                    @relation("ExamDocumentAuditPerformer", fields: [performedById], references: [id], onDelete: Cascade)
  metadata             Json?
  reason               String?                 @db.Text
  createdAt            DateTime                @default(now())

  @@index([action])
  @@index([documentType])
  @@index([registrationWindowId])
  @@index([examSessionId])
  @@index([candidateId])
  @@index([performedById])
  @@index([createdAt])
}

model Candidate {
  id                           String          @id @default(cuid())
  studentId                    String          @unique
  assessmentHubCandidateNumber String
  candidateType                CandidateType
  userId                       String?         @unique
  user                         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  studentNumber                String?
  englishName                  String
  chineseName                  String?
  surnamePinyin                String?
  givenNamePinyin              String?
  preferredEnglishName         String?
  legalEnglishName             String?
  email                        String?
  phone                        String?
  dateOfBirth                  DateTime?
  gender                       Gender?
  nationality                  String?
  idDocumentType               IdDocumentType?
  idDocumentNumber             String?
  idNumber                     String?
  passportNumber               String?
  photoUrl                     String?
  emergencyContactName         String?
  emergencyContactPhone        String?
  schoolName                   String?
  grade                        Grade?
  className                    String?
  graduationYear               Int?
  status                       CandidateStatus @default(ACTIVE)
  loginEnabled                 Boolean         @default(false)
  sourceSystem                 String?
  externalId                   String?
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt

  examIdentities         CandidateExamIdentity[]
  registrationWorkspaces RegistrationWorkspace[]
  examRegistrations      StudentExamRegistration[]
  auditLogs              RegistrationAuditLog[]
  changeRequests         RegistrationChangeRequest[]
  feeStatements          FeeStatement[]
  examDocumentAuditLogs  ExamDocumentAuditLog[]
  candidateAuditLogs     CandidateAuditLog[]
  reviewRequests         ReviewRequest[]
  cashInRequests         CashInRequest[]
  accessToScriptRequests AccessToScriptRequest[]
  certificateRequests    CertificateRequest[]
  postResultsAuditLogs   PostResultsAuditLog[]

  @@index([candidateType])
  @@index([status])
  @@index([studentId])
  @@index([assessmentHubCandidateNumber])
  @@index([studentNumber])
  @@index([englishName])
  @@index([email])
  @@index([phone])
  @@index([idNumber])
  @@index([passportNumber])
  @@index([grade])
  @@index([className])
  @@index([externalId])
}

model CandidateAuditLog {
  id            String               @id @default(cuid())
  candidateId   String
  candidate     Candidate            @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  action        CandidateAuditAction
  performedById String
  performedBy   User                 @relation("CandidateAuditPerformer", fields: [performedById], references: [id], onDelete: Cascade)
  metadata      Json?
  createdAt     DateTime             @default(now())

  @@index([candidateId])
  @@index([action])
  @@index([performedById])
  @@index([createdAt])
}

model CandidateExamIdentity {
  id                   String    @id @default(cuid())
  candidateId          String
  candidate            Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  examBoardId          String
  examBoard            ExamBoard @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  centreNumber         String?
  boardCandidateNumber String?
  uci                  String?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([candidateId, examBoardId])
  @@index([candidateId])
  @@index([examBoardId])
  @@index([boardCandidateNumber])
}

model TeacherAssignment {
  id        String   @id @default(cuid())
  teacherId String
  teacher   User     @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, subjectId])
  @@index([teacherId])
  @@index([subjectId])
}

model RegistrationWindow {
  id                             String                   @id @default(cuid())
  examBoardId                    String
  examBoard                      ExamBoard                @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  examSeriesId                   String
  examSeries                     ExamSeries               @relation(fields: [examSeriesId], references: [id], onDelete: Cascade)
  title                          String
  /// UK-style label, e.g. "2026/27" (September–August).
  academicYear                   String
  studentRegistrationOpenAt      DateTime
  studentRegistrationCloseAt     DateTime
  registrationCloseAt            DateTime
  status                         RegistrationWindowStatus @default(DRAFT)
  studentSelfRegistrationEnabled Boolean                  @default(true)
  eoAssistedRegistrationEnabled  Boolean                  @default(true)
  officeOnlyRegistrationEnabled  Boolean                  @default(true)
  postLockAdjustmentEnabled      Boolean                  @default(true)
  createdById                    String?
  createdBy                      User?                    @relation("RegistrationWindowCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt                      DateTime                 @default(now())
  updatedAt                      DateTime                 @updatedAt

  registrations         StudentExamRegistration[]
  workspaces            RegistrationWorkspace[]
  changeRequests        RegistrationChangeRequest[]
  feeStages             RegistrationFeeStage[]
  registrationAuditLogs RegistrationAuditLog[]
  feeRules              FeeRule[]
  exchangeRates         ExchangeRate[]
  feeStatements         FeeStatement[]
  feeAuditLogs          FeeAuditLog[]
  includedSeries        RegistrationWindowIncludedSeries[]
  examDocumentAuditLogs ExamDocumentAuditLog[]
  postResultsAuditLogs  PostResultsAuditLog[]

  @@index([examBoardId])
  @@index([examSeriesId])
  @@index([academicYear])
  @@index([status])
  @@index([studentRegistrationOpenAt, studentRegistrationCloseAt, registrationCloseAt], map: "RegistrationWindow_timing_idx")
}

/// Applicable exam sessions for a registration window (exam series / seasons per board).
/// Product label: "Applicable Exam Sessions". Stored as ExamSeries rows.
model RegistrationWindowIncludedSeries {
  id                   String             @id @default(cuid())
  registrationWindowId String
  registrationWindow   RegistrationWindow @relation(fields: [registrationWindowId], references: [id], onDelete: Cascade)
  examSeriesId         String
  examSeries           ExamSeries         @relation(fields: [examSeriesId], references: [id], onDelete: Cascade)
  createdAt            DateTime           @default(now())

  @@unique([registrationWindowId, examSeriesId], map: "rw_included_series_uq")
  @@index([examSeriesId])
}

model RegistrationFeeStage {
  id                   String             @id @default(cuid())
  registrationWindowId String
  registrationWindow   RegistrationWindow @relation(fields: [registrationWindowId], references: [id], onDelete: Cascade)
  stageCode            FeeEntryType
  stageName            String
  sequence             Int
  startAt              DateTime
  endAt                DateTime
  enabled              Boolean            @default(true)
  notes                String?            @db.Text
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  workspaces    RegistrationWorkspace[]
  registrations StudentExamRegistration[]
  auditLogs     RegistrationAuditLog[]

  @@unique([registrationWindowId, stageCode])
  @@index([registrationWindowId])
  @@index([enabled])
  @@index([sequence])
}

model RegistrationWorkspace {
  id                   String             @id @default(cuid())
  candidateId          String?
  candidate            Candidate?         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  studentId            String?
  student              User?              @relation("StudentRegistrationWorkspaces", fields: [studentId], references: [id], onDelete: Cascade)
  registrationWindowId String
  registrationWindow   RegistrationWindow @relation(fields: [registrationWindowId], references: [id], onDelete: Cascade)

  lockedAt                  DateTime?
  lastAdjustedByUserId      String?
  lastAdjustedByUser        User?                  @relation("WorkspaceLastAdjuster", fields: [lastAdjustedByUserId], references: [id], onDelete: SetNull)
  lastAdjustedByRole        UserRole?
  lastAdjustedAt            DateTime?
  lastAdjustmentReason      String?                @db.Text
  lastAdjustmentSummary     String?                @db.Text
  hasPostLockAdjustment     Boolean                @default(false)
  isLateRegistration        Boolean                @default(false)
  entryType                 FeeEntryType           @default(NORMAL)
  feeStageId                String?
  feeStage                  RegistrationFeeStage?  @relation(fields: [feeStageId], references: [id], onDelete: SetNull)
  entryTypeOverridden       Boolean                @default(false)
  entryTypeOverrideReason   String?                @db.Text
  registrationSource        RegistrationSource     @default(STUDENT_SUBMITTED)
  visibility                RegistrationVisibility @default(STUDENT_AND_TEACHER)
  billingScope              BillingScope           @default(NORMAL_BILLING)
  registrationType          RegistrationType       @default(INTERNAL_NORMAL)
  reason                    String?                @db.Text
  visibleToStudent          Boolean                @default(true)
  visibleToTeacher          Boolean                @default(true)
  visibleInStudentPortal    Boolean                @default(true)
  visibleInTeacherPortal    Boolean                @default(true)
  visibleInStudentDocuments Boolean                @default(true)
  visibleInStudentBilling   Boolean                @default(true)
  restrictedReason          String?                @db.Text
  restrictedCreatedById     String?
  restrictedCreatedBy       User?                  @relation("RestrictedRegistrationCreator", fields: [restrictedCreatedById], references: [id], onDelete: SetNull)
  restrictedCreatedAt       DateTime?
  restrictedUpdatedById     String?
  restrictedUpdatedBy       User?                  @relation("RestrictedRegistrationUpdater", fields: [restrictedUpdatedById], references: [id], onDelete: SetNull)
  restrictedUpdatedAt       DateTime?

  includeCandidateRegistrationFee Boolean @default(false)

  registrationNumber String? @unique
