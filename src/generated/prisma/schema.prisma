  STUDENT_REACTIVATED
  STUDENT_DELETED
  BACKUP_SETTINGS_UPDATED
  BACKUP_MANUAL_STARTED
  BACKUP_MANUAL_SUCCESS
  BACKUP_MANUAL_FAILED
