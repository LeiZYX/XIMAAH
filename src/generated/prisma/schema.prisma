model FeeSchedule {
  id                String                 @id @default(cuid())
  examBoardId       String
  examBoard         ExamBoard              @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  serviceType       FeeScheduleServiceType
  qualificationId   String?
  qualification     Qualification?         @relation(fields: [qualificationId], references: [id], onDelete: SetNull)
  subjectId         String?
  subject           Subject?               @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  paperId           String?
  paper             Paper?                 @relation(fields: [paperId], references: [id], onDelete: SetNull)
  entryType         FeeEntryType?
  reviewType        String?
  version           Int
  effectiveFrom     DateTime
  effectiveTo       DateTime?
  status            FeeScheduleStatus      @default(ACTIVE)
  costCurrency      FeeCurrency
  costAmount        Decimal                @db.Decimal(12, 2)
  salesCurrency     FeeCurrency
  salesAmount       Decimal                @db.Decimal(12, 2)
  markupType        FeeMarkupType?
  markupValue       Decimal?               @db.Decimal(12, 2)
  exchangeRateToCny Decimal?               @db.Decimal(12, 4)
  createdByUserId   String
  createdBy         User                   @relation("FeeScheduleCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  feeStatementItems FeeStatementItem[]

  @@index([examBoardId])
  @@index([serviceType])
  @@index([status])
  @@index([effectiveFrom, effectiveTo])
  @@index([version])
}

model PostResultsAuditLog {
  id                   String                  @id @default(cuid())
  action               PostResultsAuditAction
  candidateId          String?
  candidate            Candidate?              @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  examBoardId          String?
  examBoard            ExamBoard?              @relation(fields: [examBoardId], references: [id], onDelete: SetNull)
  examSeriesId         String?
  examSeries           ExamSeries?             @relation(fields: [examSeriesId], references: [id], onDelete: SetNull)
  registrationWindowId String?
  registrationWindow   RegistrationWindow?     @relation(fields: [registrationWindowId], references: [id], onDelete: SetNull)
  reviewWindowId       String?
  reviewWindow         ReviewWindow?           @relation(fields: [reviewWindowId], references: [id], onDelete: SetNull)
  serviceType          FeeScheduleServiceType?
  performedByUserId    String
  performedBy          User                    @relation("PostResultsAuditPerformer", fields: [performedByUserId], references: [id], onDelete: Cascade)
  performedAt          DateTime                @default(now())
  reason               String?                 @db.Text
  notes                String?                 @db.Text
  metadata             String?                 @db.Text

  @@index([reviewWindowId])
  @@index([registrationWindowId])
  @@index([candidateId])
  @@index([examBoardId])
  @@index([action])
  @@index([performedAt])
}

enum BackupFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum BackupType {
  DATABASE_ONLY
  DATABASE_AND_UPLOADS
}

enum BackupJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum BackupTriggeredBy {
  SCHEDULED
  MANUAL
}

model BackupSetting {
  id              String          @id @default("default")
  enabled         Boolean         @default(false)
  frequency       BackupFrequency @default(DAILY)
  backupTime      String          @default("02:00")
  backupDirectory String          @default("/var/backups/xima-assessment-hub")
  retentionDays   Int             @default(30)
  backupType      BackupType      @default(DATABASE_ONLY)
  updatedByUserId String?
  updatedBy       User?           @relation("BackupSettingsUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model BackupJob {
  id                String            @id @default(cuid())
  backupType        BackupType
  status            BackupJobStatus   @default(PENDING)
  fileName          String?
  filePath          String?
  fileSizeBytes     BigInt?
  startedAt         DateTime?
  completedAt       DateTime?
  errorMessage      String?           @db.Text
  triggeredBy       BackupTriggeredBy
  triggeredByUserId String?
  triggeredByUser   User?             @relation("BackupJobTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([triggeredBy])
}
