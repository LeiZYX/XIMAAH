  USER_DEACTIVATED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  PASSWORD_FORCE_SET_BY_ADMIN
  STUDENT_IMPORTED
  TEACHER_IMPORTED
