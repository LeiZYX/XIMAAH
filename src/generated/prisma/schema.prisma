  CANDIDATE_IDENTITY_UPDATED
  CANDIDATE_PHOTO_UPLOADED
  CANDIDATE_PHOTO_REMOVED
  CANDIDATE_NAME_CHANGED
  DOCUMENT_NUMBER_CHANGED
